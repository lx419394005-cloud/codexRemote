{
  "name": "codex-bridge",
  "version": "1.0.0",
  "description": "A secure bridge to access Codex CLI remotely via JSON-RPC over WebSocket",
  "main": "bridge.js",
  "scripts": {
    "dev": "next dev --webpack --hostname 0.0.0.0 --port ${FRONTEND_PORT:-8080}",
    "dev:bridge": "NODE_ENV=development BRIDGE_PORT=${BRIDGE_PORT:-8081} node bridge.js",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port ${FRONTEND_PORT:-8080}",
    "start:bridge": "NODE_ENV=production BRIDGE_PORT=${BRIDGE_PORT:-8081} node bridge.js"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.16.0"
  }
}
